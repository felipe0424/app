    min-height: 0;
    margin-right: 0;
    overflow: visible;
    isolation: isolate;
    background: transparent;
  }

  .image4-photo {
    position: relative;
    z-index: 1;
    display: block;
    width: min(128%, 900px);
    max-width: none;
    height: auto;
    transform: none;
    object-fit: contain;
    object-position: bottom center;
  }

  .split-fold-cream .image4-photo {
    /* mix-blend-mode: lighten; */
    opacity: 1;
    /*filter: saturate(1.03) contrast(1.02);*/
  }

  .results-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(60px, 6vw, 88px) 0 clamp(56px, 5vw, 76px);
    color: #00183e;
    background: #eee5a6;
  }

  .results-marquee-container {
    width: min(calc(100% - (var(--page-gutter) * 2)), var(--page-max));
    margin-top: 42px;
    margin-right: auto;
    margin-left: auto;
    overflow: hidden;
    padding: 0 0 12px;
  }

  .results-marquee-track {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .results-marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 10px)); }
  }

  .result-card {
    flex: 0 0 clamp(210px, 17vw, 300px);
    height: clamp(320px, 34vw, 430px);
    overflow: hidden;
    background: rgba(0, 24, 62, 0.08);
    border-radius: 8px;
  }

  .result-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }



  .centered-cta-fold {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: min(78svh, 720px);
    padding: clamp(66px, 6vw, 92px) var(--section-pad);
    color: #ffffff;
    background: linear-gradient(126deg, #00183e 36%, #00255f 100%);
  }

  .centered-copy {
    max-width: var(--page-narrow);
    text-align: center;
  }

  .centered-copy p:first-child {
    margin: 0 0 22px;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .centered-copy h2 {
    max-width: 760px;
    margin: 0 auto;
    font-size: clamp(2.15rem, 3vw, 3.1rem);
    color: #ffffff;
  }

  .centered-copy p:not(:first-child) {
    max-width: var(--page-narrow);
    margin: 30px auto 0;
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .feature-fold-compact {
    min-height: min(92svh, 820px);
  }

  /* ═══════════════════════════════════════════════════════
     METHODOLOGY FOLD
  ═══════════════════════════════════════════════════════ */
  .methodology-fold {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    padding: clamp(80px, 8vw, 112px) var(--section-pad);
    background: linear-gradient(160deg, #020c22 0%, #001535 100%);
    overflow: clip;
  }

  .methodology-inner {
    width: min(100%, var(--page-max));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(260px, 340px) 1fr;
    gap: clamp(48px, 6vw, 80px);
    align-items: start;
  }

  .methodology-heading {
    position: sticky;
    top: clamp(80px, 10vw, 120px);
  }

  .methodology-heading h2 {
    margin: 10px 0 18px;
    font-size: clamp(2rem, 2.8vw, 2.8rem);
    font-weight: 700;
    line-height: 1.06;
    color: #e4d694;
    font-family: var(--font-display);
  }

  .methodology-sub {
    font-size: 1.02rem;
    color: rgba(228, 214, 148, 0.52);
    line-height: 1.45;
    margin: 0;
  }

  .methodology-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  /* linha vertical conectora */
  .methodology-list::before {
    content: '';
    position: absolute;
    left: 27px;
    top: 54px;
    bottom: 54px;
    width: 1px;
    background: linear-gradient(to bottom, rgba(208,179,98,0.4), rgba(208,179,98,0.08));
    z-index: 0;
  }

  .methodology-item {
    display: grid;
    grid-template-columns: 56px 54px 1fr;
    align-items: start;
    gap: 0 18px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(228, 214, 148, 0.07);
    position: relative;
    z-index: 1;
    transition: background 0.28s ease;
    border-radius: 12px;
    padding-left: 4px;
    padding-right: 12px;
  }

  .methodology-item:last-child {
    border-bottom: none;
  }

  .methodology-item:hover {
    background: rgba(228, 214, 148, 0.04);
  }

  .methodology-num {
    font-size: clamp(2rem, 2.8vw, 2.8rem);
    font-weight: 800;
    line-height: 1;
    font-family: var(--font-display);
    color: rgba(208, 179, 98, 0.22);
    padding-top: 6px;
    transition: color 0.28s ease;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .methodology-item:hover .methodology-num {
    color: rgba(208, 179, 98, 0.55);
  }

  .methodology-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(208, 179, 98, 0.09);
    border: 1px solid rgba(208, 179, 98, 0.18);
    border-radius: 12px;
    flex: 0 0 auto;
    transition: background 0.28s ease, border-color 0.28s ease;
    margin-top: 2px;
  }

  .methodology-item:hover .methodology-icon {
    background: rgba(208, 179, 98, 0.16);
    border-color: rgba(208, 179, 98, 0.36);
  }

  .methodology-icon svg {
    width: 22px;
    height: 22px;
  }

  .methodology-body {
    padding-top: 4px;
  }

  .methodology-body h3 {
    margin: 0 0 8px;
    font-size: clamp(1.1rem, 1.4vw, 1.28rem);
    font-weight: 700;
    color: #e4d694;
    font-family: var(--font-display);
    line-height: 1.1;
  }

  .methodology-body p {
    margin: 0;
    font-size: 0.98rem;
    color: rgba(228, 214, 148, 0.58);
    line-height: 1.48;
  }

  @media (max-width: 860px) {
    .methodology-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .methodology-heading {
      position: static;
    }
    .methodology-list::before {
      left: 25px;
    }
  }

  @media (max-width: 520px) {
    .methodology-item {
      grid-template-columns: 40px 46px 1fr;
      gap: 0 12px;
    }
    .methodology-num {
      font-size: 1.6rem;
    }
    .methodology-icon {
      width: 42px;
      height: 42px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     FAQ FOLD
  ═══════════════════════════════════════════════════════ */
  .faq-fold {
    width: 100%;
    box-sizing: border-box;
    padding: clamp(80px, 8vw, 112px) var(--section-pad);
    background: #00183e;
  }

  .faq-inner {
    width: min(100%, var(--page-max));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(240px, 320px) 1fr;
    gap: clamp(48px, 6vw, 80px);
    align-items: start;
  }

  .faq-heading {
    position: sticky;
    top: clamp(80px, 10vw, 120px);
  }

  .faq-heading h2 {
    margin: 10px 0 18px;
    font-size: clamp(2.4rem, 3vw, 3.2rem);
    font-weight: 800;
    line-height: 1.0;
    color: #e4d694;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .faq-sub {
    margin: 0;
    font-size: 0.96rem;
    color: rgba(228, 214, 148, 0.45);
    line-height: 1.48;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid rgba(228, 214, 148, 0.1);
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(228, 214, 148, 0.1);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 22px 4px;
    cursor: pointer;
    list-style: none;
    font-size: clamp(1rem, 1.2vw, 1.14rem);
    font-weight: 700;
    color: #e4d694;
    font-family: var(--font-display);
    transition: color 0.2s ease;
    user-select: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary:hover {
    color: #fffbd0;
  }

  .faq-icon {
    width: 22px;
    height: 22px;
    flex: 0 0 auto;
    color: rgba(228, 214, 148, 0.5);
    transition: transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.2s ease;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    color: #d0b362;
  }

  .faq-item[open] > summary {
    color: #fffbd0;
  }

  .faq-body {
    overflow: hidden;
  }

  .faq-body p {
    margin: 0;
    padding: 0 4px 24px;
    font-size: 1rem;
    color: rgba(228, 214, 148, 0.6);
    line-height: 1.52;
  }

  /* ═══════════════════════════════════════════════════════
     ABOUT FOLD
  ═══════════════════════════════════════════════════════ */
  .about-fold {
    width: 100%;
    box-sizing: border-box;
    padding: clamp(80px, 8vw, 112px) var(--section-pad);
    background: linear-gradient(135deg, #020c22 0%, #001a48 100%);
  }

  .about-inner {
    width: min(100%, var(--page-max));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 400px) 1fr;
    gap: clamp(48px, 6vw, 88px);
    align-items: center;
  }

  .about-photo-wrap {
    position: relative;
  }

  .about-photo {
    display: block;
    width: 100%;
    height: min(68svh, 600px);
    object-fit: cover;
    object-position: center top;
    border-radius: 16px;
    filter: grayscale(18%);
  }

  .about-photo-badge {
    position: absolute;
    bottom: 20px;
    right: -18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #d0b362, #fffbd0);
    border-radius: 50%;
    box-shadow: 0 8px 24px rgba(0,0,0,0.38);
  }

  .about-photo-badge span {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #00183e;
    font-family: var(--font-display);
    line-height: 1;
  }

  .about-photo-badge strong {
    font-size: 1.1rem;
    font-weight: 900;
    color: #00183e;
    font-family: var(--font-display);
    line-height: 1;
  }

  .about-copy h2 {
    margin: 10px 0 20px;
    font-size: clamp(2.2rem, 3vw, 3.2rem);
    font-weight: 800;
    color: #ffffff;
    font-family: var(--font-display);
    line-height: 1.0;
    letter-spacing: -0.01em;
  }

  .about-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .about-chip {
    display: inline-block;
    padding: 5px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #d0b362;
    background: rgba(208, 179, 98, 0.1);
    border: 1px solid rgba(208, 179, 98, 0.28);
    border-radius: 100px;
  }

  .about-copy p {
    margin: 0 0 28px;
    font-size: 1.04rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .faq-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .faq-heading {
      position: static;
    }
    .about-inner {
      grid-template-columns: 1fr;
      max-width: 560px;
    }
    .about-photo {
      height: min(60svh, 480px);
    }
    .about-photo-badge {
      right: 12px;
    }
  }

  /* ═══════════════════════════════════════════════════════
     CONTACT FOLD
  ═══════════════════════════════════════════════════════ */
  .contact-fold {
    width: 100%;
    box-sizing: border-box;
    padding: clamp(80px, 8vw, 112px) var(--section-pad);
    background: linear-gradient(160deg, #00183e 0%, #002a6a 100%);
    position: relative;
    overflow: clip;
  }

  /* decorative large ghost text behind */
  .contact-fold::before {
    content: 'CTA';
    position: absolute;
    right: -2%;
    bottom: -14%;
    font-family: var(--font-display);
    font-size: 28vw;
    font-weight: 800;
    color: rgba(228, 214, 148, 0.025);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.04em;
  }

  .contact-inner {
    width: min(100%, var(--page-max));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    gap: clamp(48px, 6vw, 88px);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .contact-header h2 {
    margin: 10px 0 20px;
    font-size: clamp(2.4rem, 3.4vw, 3.6rem);
    font-weight: 800;
    line-height: 1.0;
    color: #ffffff;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .contact-sub {
    margin: 0;
    font-size: 1.04rem;
    color: rgba(255, 255, 255, 0.52);
    line-height: 1.48;
    max-width: 340px;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 26px 30px;
    border-radius: 16px;
    text-decoration: none;
    transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.28s ease, background 0.22s ease;
    position: relative;
    overflow: clip;
  }

  .contact-card:hover {
    transform: translateX(6px);
  }

  .contact-card-primary {
    background: #e4d694;
    color: #00183e;
    box-shadow: 0 8px 28px rgba(228, 214, 148, 0.18);
  }

  .contact-card-primary:hover {
    background: #fffbd0;
    box-shadow: 0 16px 42px rgba(228, 214, 148, 0.28);
  }

  .contact-card-secondary {
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(228, 214, 148, 0.2);
    color: #e4d694;
  }

  .contact-card-secondary:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(228, 214, 148, 0.38);
  }

  .contact-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    background: rgba(0, 24, 62, 0.1);
    border-radius: 12px;
  }

  .contact-card-primary .contact-card-icon {
    background: rgba(0, 24, 62, 0.12);
  }

  .contact-card-secondary .contact-card-icon {
    background: rgba(228, 214, 148, 0.08);
    border: 1px solid rgba(228, 214, 148, 0.15);
  }

  .contact-card-icon svg {
    width: 26px;
    height: 26px;
  }

  .contact-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .contact-card-body strong {
    font-size: 1.22rem;
    font-weight: 700;
    font-family: var(--font-display);
    line-height: 1;
  }

  .contact-card-body span {
    font-size: 1.02rem;
    font-weight: 500;
    opacity: 0.82;
  }

  .contact-card-body small {
    font-size: 0.88rem;
    opacity: 0.56;
    line-height: 1.3;
  }

  .contact-card-arrow {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
    opacity: 0.5;
    transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), opacity 0.22s ease;
  }

  .contact-card:hover .contact-card-arrow {
    transform: translateX(4px);
    opacity: 1;
  }

  /* ═══════════════════════════════════════════════════════
     FOOTER
  ═══════════════════════════════════════════════════════ */
  .site-footer {
    width: 100%;
    background: #020a1e;
    border-top: 1px solid rgba(228, 214, 148, 0.08);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(180px, 240px) 1fr minmax(200px, 320px);
    align-items: start;
    gap: clamp(28px, 4vw, 56px);
    width: min(calc(100% - (var(--page-gutter) * 2)), var(--page-max));
    margin: 0 auto;
    padding: clamp(52px, 5vw, 72px) 0 clamp(36px, 3vw, 52px);
  }

  .footer-logo {
    display: block;
    width: min(100%, 188px);
    margin-bottom: 18px;
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: rgba(228, 214, 148, 0.35);
    line-height: 1.5;
    margin: 0;
  }

  .footer-col-label {
    margin: 0 0 16px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(228, 214, 148, 0.3);
    font-family: var(--font-display);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.92rem;
    color: rgba(228, 214, 148, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #e4d694;
  }

  .footer-links a svg {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .footer-locations {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .footer-location-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .footer-location-item > svg {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
    margin-top: 2px;
  }

  .footer-location-item > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .footer-location-item strong {
    font-size: 0.9rem;
    font-weight: 700;
    color: rgba(228, 214, 148, 0.7);
    font-family: var(--font-display);
    line-height: 1.1;
  }

  .footer-location-item span {
    font-size: 0.82rem;
    color: rgba(228, 214, 148, 0.38);
    line-height: 1.35;
  }

  .footer-bottom {
    border-top: 1px solid rgba(228, 214, 148, 0.06);
    padding: 18px var(--section-pad);
    text-align: center;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(228, 214, 148, 0.22);
  }

  @media (min-width: 1800px) {
    .home-page {
      --page-max: 1120px;
      --page-gutter: clamp(22px, 4vw, 64px);
    }

    .site-nav {
      gap: clamp(18px, 1.2vw, 24px);
      font-size: 0.92rem;
    }

    .private-access {
      min-width: 210px;
      font-size: 0.86rem;
    }

    .hero-title {
      font-size: 4.35rem;
    }

    .hero-text {
      font-size: 1.02rem;
    }
  }

  @media (max-width: 1390px) {
    .site-header {
      grid-template-columns: minmax(190px, 270px) minmax(0, 1fr) minmax(188px, 202px);
      gap: 14px;
    }

    .site-nav {
      gap: clamp(12px, 1.25vw, 18px);
      font-size: 0.78rem;
    }

    .private-access {
      min-width: 188px;
      min-height: 38px;
      gap: 8px;
      padding: 0 14px;
      font-size: 0.76rem;
    }

    .hero-content {
      grid-template-columns: minmax(0, 460px) minmax(0, 460px);
      gap: 24px;
      padding-top: clamp(78px, 7vw, 104px);
      padding-bottom: clamp(44px, 5vw, 68px);
    }

    .hero-kicker {
      font-size: 1rem;
    }

    .hero-title {
      max-width: 440px;
      font-size: 3rem;
    }

    .hero-text {
      max-width: 500px;
      font-size: 0.9rem;
    }

    .fabiano-photo {
      height: clamp(360px, 54svh, 500px);
    }

    .hero-element {
      width: 9rem;
    }

    .section-heading h2,
    .split-copy h2 {
      font-size: 2.3rem;
    }

    .section-heading p {
      font-size: 1.05rem;
    }

    .cream-board {
      padding: 46px 5vw 58px;
    }

    .feature-grid {
      gap: 26px;
      max-width: 900px;
    }

    .feature-card h3 {
      font-size: 1.02rem;
    }

    .feature-card p {
      font-size: 0.95rem;
    }

    .split-fold {
      grid-template-columns: minmax(350px, 470px) minmax(420px, 580px);
      gap: 34px;
    }

    .split-fold-cream {
      grid-template-columns: minmax(280px, 400px) minmax(520px, 760px);
      gap: 24px;
      min-height: clamp(410px, 54svh, 510px);
      padding-top: 0;
      padding-bottom: 0;
    }

    .image4-photo {
      width: min(126%, 820px);
    }

    .section-kicker {
      font-size: 1.1rem;
      margin-bottom: 18px;
    }

    .split-copy p:not(.section-kicker) {
      font-size: 0.98rem;
    }

    .section-cta {
      min-width: 238px;
      min-height: 44px;
      font-size: 0.95rem;
    }

    .result-card {
      height: 360px;
    }

    .centered-copy h2 {
      font-size: 2.55rem;
    }

    .centered-copy p:not(:first-child) {
      font-size: 1.08rem;
    }

    .contact-fold .contact-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (min-width: 1181px) and (max-height: 760px) {
    .site-header {
      padding-top: 16px;
    }

    .brand-link {
      max-width: 250px;
    }

    .site-nav {
      gap: clamp(10px, 1vw, 16px);
      font-size: 0.7rem;
    }

    .private-access {
      min-width: 174px;
      min-height: 34px;
      gap: 8px;
      padding: 0 12px;
      font-size: 0.68rem;
    }

    .private-icon {
      width: 17px;
      height: 17px;
    }

    .hero-content {
      grid-template-columns: minmax(0, 420px) minmax(0, 400px);
      gap: 22px;
      padding-top: 66px;
      padding-bottom: 36px;
    }

    .hero-copy {
      max-width: 480px;
      transform: none;
    }

    .hero-kicker {
      margin-bottom: 12px;
      font-size: 0.9rem;
    }

    .hero-title {
      max-width: 420px;
      font-size: clamp(2.35rem, 3.25vw, 2.9rem);
      line-height: 0.96;
    }

    .hero-text {
      max-width: 460px;
      margin-top: 18px;
      font-size: 0.82rem;
      line-height: 1.28;
    }

    .hero-cta {
      min-width: 172px;
      min-height: 36px;
      gap: 16px;
      margin-top: 24px;
      font-size: 0.78rem;
    }

    .hero-cta-icon {
      width: 17px;
      height: 17px;
    }

    .fabiano-photo {
      height: clamp(300px, 50svh, 430px);
    }

    .hero-element {
      width: 7.8rem;
      bottom: 7svh;
    }

    .scroll-cue {
      bottom: 12px;
      gap: 8px;
      font-size: 0.74rem;
    }

    .scroll-icon {
      width: 16px;
      height: 20px;
    }
  }

  @media (max-width: 1180px) {
    .site-header {
      position: absolute;
      right: 0;
      left: 0;
      display: flex;
      width: auto;
      margin: 0;
      padding: 22px 22px 0;
    }

    .site-header.is-floating {
      position: absolute;
      top: auto;
      width: auto;
      margin: 0;
      padding: 22px 22px 0;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      backdrop-filter: none;
    }

    .brand-link {
      width: 235px;
      max-width: 70vw;
    }

    .site-nav,
    .private-access,
    .scroll-cue {
      display: none;
    }

    .hero-content {
      position: relative;
      display: block;
      top: auto;
      right: auto;
      bottom: auto;
      left: auto;
      width: min(calc(100% - 48px), 760px);
      min-height: calc(100svh - 88px);
      margin: 0 auto;
      padding: 56px 0 0;
      transform: none;
    }

    .hero-copy {
      max-width: 560px;
      margin: 0 auto;
      transform: none;
    }

    .hero-kicker {
      font-size: 1rem;
    }

    .hero-title {
      max-width: 460px;
      font-size: 2.9rem;
      line-height: 1;
    }

    .hero-text {
      max-width: 540px;
      font-size: 0.92rem;
      line-height: 1.35;
    }

    .hero-cta {
      min-width: 204px;
      min-height: 44px;
      margin-top: 34px;
    }

    .hero-visual {
      position: absolute;
      right: -80px;
      bottom: 0;
      width: 420px;
      height: 52svh;
      opacity: 0.6;
    }

    .fabiano-photo {
      right: 0;
      height: 100%;
      animation: hero-float 6s ease-in-out 1s infinite;
    }

    .hero-element {
      display: none;
    }

    .landing-fold {
      min-height: auto;
    }

    .feature-fold,
    .centered-cta-fold,
    .split-fold,
    .contact-fold {
      padding: 58px 24px;
    }

    .cream-board {
      padding: 44px 24px 54px;
    }

    .section-heading h2,
    .centered-copy h2,
    .split-copy h2 {
      font-size: 1.95rem;
      line-height: 1.08;
    }

    .section-heading p,
    .centered-copy p:not(:first-child),
    .split-copy p:not(.section-kicker) {
      font-size: 0.95rem;
      line-height: 1.42;
    }

    .feature-grid {
      grid-template-columns: 1fr;
      gap: 22px;
      margin-top: 42px;
    }

    .feature-card {
      min-height: auto;
      padding: 22px;
    }

    .feature-card h3 {
      font-size: 1.05rem;
    }

    .feature-card p {
      font-size: 1rem;
    }

    .split-fold {
      display: grid;
      grid-template-columns: 1fr;
      gap: 38px;
    }

    .split-fold-cream {
      justify-items: center;
      min-height: auto;
      gap: 30px;
      padding: 0 24px 0;
    }

    .image4-stage {
      width: min(100%, 700px);
      min-height: 0;
      margin: 0;
      justify-self: center;
    }

    .image4-photo {
      width: min(112%, 660px);
      object-position: bottom center;
    }

    .results-fold {
      padding: 68px 0;
    }

    .results-marquee-container {
      padding: 0 24px 10px;
    }

    .result-card {
      height: 320px;
      flex: 0 0 clamp(230px, 45vw, 290px);
    }

    .slider-actions {
      display: none;
    }

    .centered-copy p:first-child,
    .section-kicker {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 560px) {
    .hero-title {
      font-size: 2.3rem;
    }

    .hero-text {
      font-size: 0.88rem;
    }

    .hero-visual {
      right: -185px;
      width: 390px;
      opacity: 0.34;
    }

    .feature-fold,
    .centered-cta-fold,
    .split-fold {
      padding-right: 18px;
      padding-left: 18px;
    }

    .cream-board {
      padding: 30px 18px 38px;
    }

    .section-heading h2,
    .centered-copy h2,
    .split-copy h2 {
      font-size: 1.82rem;
    }

    .section-cta {
      width: 100%;
      min-width: 0;
      font-size: 0.92rem;
    }

    .image4-stage {
      width: 100%;
      min-height: 0;
    }

    .image4-photo {
      width: min(108%, 500px);
    }

    .result-card {
      height: 300px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     SCROLL REVEAL
  ═══════════════════════════════════════════════════════════════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ═══════════════════════════════════════════════════════════════════
     KICKERS & HEADING HELPERS
  ═══════════════════════════════════════════════════════════════════ */
  .section-kicker-light {
    display: block;
    margin: 0 0 14px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(228, 214, 148, 0.5);
    font-family: var(--font-display);
  }

  .section-kicker-gold {
    display: block;
    margin: 0 0 14px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d0b362;
    font-family: var(--font-display);
  }

  .section-kicker-navy {
    display: block;
    margin: 0 0 14px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(0, 24, 62, 0.5);
    font-family: var(--font-display);
  }

  .heading-gold {
    color: #e4d694 !important;
  }

  .heading-muted {
    color: rgba(228, 214, 148, 0.65) !important;
  }

  /* ═══════════════════════════════════════════════════════════════════
     STATS CARD OVERRIDE
  ═══════════════════════════════════════════════════════════════════ */
  /* stats-fold responsive */
  @media (max-width: 860px) {
    .stats-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .stats-item:nth-child(2) { border-right: none; }
    .stats-item:nth-child(1),
    .stats-item:nth-child(2) {
      border-bottom: 1px solid rgba(228, 214, 148, 0.1);
    }
  }
  @media (max-width: 480px) {
    .stats-strip {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     CARD HOVER LIFT
  ═══════════════════════════════════════════════════════════════════ */
  .feature-card {
    transition: transform 0.26s ease, box-shadow 0.26s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 30px rgba(0, 24, 62, 0.18);
  }

  /* ═══════════════════════════════════════════════════════════════════
     AUDIENCE FOLD
  ═══════════════════════════════════════════════════════════════════ */
  .audience-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: clamp(72px, 7vw, 104px) var(--section-pad);
    background: #00183e;
  }

  .audience-inner {
    width: min(100%, var(--page-max));
  }

  .audience-fold .section-heading {
    max-width: min(760px, var(--page-narrow));
    margin: 0 auto 52px;
    text-align: center;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .audience-card {
    padding: 28px 24px;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(228, 214, 148, 0.14);
    border-radius: 14px;
    transition: transform 0.26s ease, background 0.26s ease, border-color 0.26s ease;
  }

  .audience-card:hover {
    transform: translateY(-5px);
    background: rgba(228, 214, 148, 0.055);
    border-color: rgba(228, 214, 148, 0.28);
  }

  .audience-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    margin-bottom: 16px;
    background: rgba(208, 179, 98, 0.1);
    border-radius: 10px;
  }

  .audience-card-icon svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: #d0b362;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .audience-card h3 {
    margin: 0 0 10px;
    font-size: 1.12rem;
    font-weight: 700;
    color: #e4d694;
    font-family: var(--font-display);
    line-height: 1.1;
  }

  .audience-card p {
    margin: 0;
    font-size: 1rem;
    color: rgba(228, 214, 148, 0.65);
    line-height: 1.35;
  }

  /* ═══════════════════════════════════════════════════════════════════
     PROGRAMS FOLD
  ═══════════════════════════════════════════════════════════════════ */
  .programs-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: clamp(72px, 7vw, 100px) var(--section-pad);
    background: linear-gradient(160deg, #020c22 0%, #001535 100%);
  }

  .programs-inner {
    width: min(100%, var(--page-max));
  }

  .programs-fold .section-heading {
    max-width: min(760px, var(--page-narrow));
    margin: 0 auto 56px;
    text-align: center;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    align-items: start;
  }

  .program-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: clamp(26px, 3vw, 40px);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(228, 214, 148, 0.18);
    border-radius: 18px;
    color: #e4d694;
    transition: transform 0.28s ease, box-shadow 0.28s ease;
  }

  .program-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.38);
  }

  .program-card-featured {
    border-color: rgba(208, 179, 98, 0.42);
    background: rgba(208, 179, 98, 0.055);
  }

  .program-badge-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .program-badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(228, 214, 148, 0.1);
    border: 1px solid rgba(228, 214, 148, 0.22);
    border-radius: 4px;
    color: rgba(228, 214, 148, 0.65);
    font-family: var(--font-display);
  }

  .program-badge-gold {
    background: rgba(208, 179, 98, 0.16);
    border-color: rgba(208, 179, 98, 0.38);
    color: #d0b362;
  }

  .program-featured-tag {
    display: inline-block;
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    background: linear-gradient(90deg, #d0b362, #fffbd0);
    color: #00183e;
    border-radius: 4px;
    font-family: var(--font-display);
  }

  .program-card h3 {
    margin: 0;
    font-size: clamp(1.45rem, 2vw, 1.9rem);
    font-weight: 700;
    color: #e4d694;
    font-family: var(--font-display);
    line-height: 1.05;
  }

  .program-subtitle {
    margin: -10px 0 0;
    font-size: 0.95rem;
    color: rgba(228, 214, 148, 0.5);
    line-height: 1.3;
  }

  .program-desc {
    margin: 0;
    font-size: 0.98rem;
    color: rgba(228, 214, 148, 0.7);
    line-height: 1.42;
  }

  .program-features {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .program-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.96rem;
    color: rgba(228, 214, 148, 0.78);
    line-height: 1.3;
  }

  .program-features li::before {
    content: '✓';
    flex: 0 0 auto;
    color: #d0b362;
    font-weight: 700;
    font-size: 0.9rem;
    margin-top: 1px;
  }

  .program-note {
    margin: 0;
    padding: 11px 14px;
    font-size: 0.88rem;
    color: rgba(228, 214, 148, 0.55);
    background: rgba(208, 179, 98, 0.07);
    border-left: 2px solid rgba(208, 179, 98, 0.35);
    border-radius: 0 6px 6px 0;
    line-height: 1.35;
  }

  .program-price-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 7px;
    padding: 20px 22px;
    background: linear-gradient(135deg, rgba(208,179,98,0.13) 0%, rgba(228,214,148,0.04) 100%);
    border: 1px solid rgba(208,179,98,0.45);
    border-radius: 12px;
  }

  .program-price-row {
    display: flex;
    align-items: baseline;
    gap: 3px;
    line-height: 1;
  }

  .price-currency {
    font-size: 1.1rem;
    font-weight: 700;
    color: #d0b362;
    font-family: var(--font-display);
    align-self: flex-start;
    margin-top: 5px;
  }

  .price-amount {
    font-size: clamp(2.4rem, 4vw, 3.2rem);
    font-weight: 800;
    color: #fffbd0;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .price-cents {
    font-size: 1.15rem;
    font-weight: 600;
    color: rgba(255,251,208,0.55);
    font-family: var(--font-display);
    align-self: flex-start;
    margin-top: 5px;
  }

  .price-avista {
    display: inline-block;
    padding: 3px 11px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    background: rgba(208,179,98,0.18);
    border: 1px solid rgba(208,179,98,0.42);
    color: #d0b362;
    border-radius: 4px;
    font-family: var(--font-display);
  }

  .program-price-sub {
    font-size: 0.8rem;
    color: rgba(228, 214, 148, 0.42);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .program-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 13px 22px;
    font-size: 0.96rem;
    font-weight: 600;
    text-decoration: none;
    background: rgba(228, 214, 148, 0.1);
    border: 1px solid rgba(228, 214, 148, 0.28);
    color: #e4d694;
    border-radius: 10px;
    font-family: var(--font-display);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .program-cta:hover {
    background: rgba(228, 214, 148, 0.16);
    border-color: rgba(228, 214, 148, 0.45);
    transform: translateY(-2px);
  }

  .program-cta svg {
    width: 17px;
    height: 17px;
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .program-cta-featured {
    background: linear-gradient(90deg, #d0b362 0%, #fffbd0 100%);
    border-color: transparent;
    color: #00183e;
  }

  .program-cta-featured:hover {
    background: linear-gradient(90deg, #dbc777 0%, #fffce0 100%);
    border-color: transparent;
  }

  /* ═══════════════════════════════════════════════════════════════════
     TESTIMONIALS FOLD
  ═══════════════════════════════════════════════════════════════════ */
  .testimonials-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: clamp(72px, 7vw, 100px) var(--section-pad);
    background: #eee5a6;
    color: #00183e;
  }

  .testimonials-inner {
    width: min(100%, var(--page-max));
  }

  .testimonials-fold .section-heading {
    max-width: min(760px, var(--page-narrow));
    margin: 0 auto 52px;
    text-align: center;
    color: #00183e;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: 13px;
    padding: 22px 20px;
    background: rgba(0, 24, 62, 0.05);
    border: 1px solid rgba(0, 24, 62, 0.1);
    border-radius: 14px;
    transition: transform 0.26s ease, box-shadow 0.26s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(0, 24, 62, 0.1);
  }

  .testimonial-stars {
    margin: 0;
    font-size: 0.92rem;
    color: #d0b362;
    letter-spacing: 0.08em;
  }

  .testimonial-body {
    margin: 0;
    flex: 1;
    font-size: 0.98rem;
    color: rgba(0, 24, 62, 0.78);
    line-height: 1.48;
    font-style: italic;
  }

  .testimonial-footer {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-top: 11px;
    border-top: 1px solid rgba(0, 24, 62, 0.1);
  }

  .testimonial-footer strong {
    font-size: 0.96rem;
    font-weight: 700;
    color: #00183e;
    font-family: var(--font-display);
    line-height: 1;
  }

  .testimonial-footer span {
    font-size: 0.84rem;
    color: rgba(0, 24, 62, 0.48);
  }

  /* ═══════════════════════════════════════════════════════════════════
     AUTHORITY FOLD
  ═══════════════════════════════════════════════════════════════════ */
  .authority-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: clamp(72px, 7vw, 100px) var(--section-pad);
    background: linear-gradient(160deg, #020c22 0%, #001535 100%);
  }

  .authority-inner {
    width: min(100%, var(--page-max));
  }

  .authority-fold .section-heading {
    max-width: min(760px, var(--page-narrow));
    margin: 0 auto 52px;
    text-align: center;
  }

  .authority-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .authority-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    padding: 30px 26px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(228, 214, 148, 0.12);
    border-radius: 14px;
    transition: border-color 0.26s ease, background 0.26s ease, transform 0.26s ease;
  }

  .authority-item:hover {
    border-color: rgba(228, 214, 148, 0.26);
    background: rgba(228, 214, 148, 0.04);
    transform: translateY(-4px);
  }

