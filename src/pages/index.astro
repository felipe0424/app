const menuItems = ['Início', 'Especialidades', 'Cursos', 'Avaliações', 'Sobre', 'Contatos'];

const featureCards = [
  {
    title: 'Lorem ipsum dolor sit amet',
    text: 'Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.',
  },
  {
    title: 'Lorem ipsum dolor sit amet',
    text: 'Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.',
  },
  {
    title: 'Lorem ipsum dolor sit amet',
    text: 'Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.',
  },
  {
    title: 'Lorem ipsum dolor sit amet',
    text: 'Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.',
  },
];

const resultCards = [
  { image: fabiano, label: 'franca.beta' },
  { image: image1, label: 'nutrifabianomoura' },
  { image: image4, label: 'clinica fabiano moura' },
  { image: image5, label: 'vanicleia.p' },
  { image: image2, label: 'resultado' },
  { image: image4, label: 'depoimento' },
];

const accordionItems = [
  {
    title: 'Lorem ipsum dolor sit amet consectetur',
    text: 'Lorem ipsum dolor sit amet consectetur. Porta nibh ultricies feugiat tincidunt donec purus. Egestas malesuada urna cursus venenatis elementum gravida ac tellus feugiat.',
  },
  {
    title: 'Lorem ipsum dolor sit amet consectetur',
    text: 'Nisl velit faucibus adipiscing nec non nulla viverra. Ornare ut vel turpis quam. Sit purus neque sed sit amet pellentesque a ligula.',
  },
  {
    title: 'Lorem ipsum dolor sit amet consectetur',
    text: 'Felis nulla id leo cras turpis. Urna viverra est dolor mi convallis aliquam. Pharetra tristique libero et in molestie faucibus aenean.',
  },
  {
    title: 'Lorem ipsum dolor sit amet consectetur',
    text: 'Faucibus lacus mauris viverra eget. Sed quam et ullamcorper neque sit sit augue condimentum risus.',
  },
  {
    title: 'Lorem ipsum dolor sit amet consectetur',
    text: 'Lectus fermentum neque sed tortor aliquet eget dictumst sed. Nulla ut congue tempor ultrices cursus.',
  },
];
---

<Layout title="Fabiano Moura | Excelência Nutricional">
  <main class="home-page text-text bg-background w-full max-w-full box-border justify-center items-center overflow-hidden">
    <section id="inicio" class="hero-shell">
      <Image
        src={bgHero}
        alt=""
        loading="eager"
        class="hero-bg"
      />

      <header class="site-header">
        <a href="#inicio" class="brand-link" aria-label="Fabiano Moura Excelência Nutricional">
          <Image src={logoPrincipal} alt="Fabiano Moura Excelência Nutricional" loading="eager" class="brand-logo" />
        </a>

        <nav class="site-nav" aria-label="Navegação principal">
          {menuItems.map((item) => (
            <a href={`#${item.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')}`}>
              {item}
            </a>
          ))}
        </nav>

        <a
          href="/login"
          class="private-access"
        >
          <span>Acesso Exclusivo</span>
          <Image src={fire} alt="" width={24} height={24} loading="eager" class="private-icon" />
        </a>
      </header>

      <div class="hero-content">
        <div class="hero-copy">
          <p class="hero-kicker">
            Você está em busca da
          </p>

          <h1 class="hero-title">
            Excelência
            <span class="block">Nutricional?</span>
          </h1>

          <p class="hero-text">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Magnam quam repellat vero non mollitia cum est voluptates. Lorem ipsum dolor sit amet consectetur adipisicing elit. Magnam quam repellat vero non mollitia cum est voluptates. Lorem ipsum dolor sit amet consectetur adipisicing elit. Magnam quam repellat vero non mollitia cum est voluptates. Lorem ipsum dolor sit amet consectetur adipisicing elit. Magnam quam repellat vero non mollitia cum est voluptates.
          </p>

          <a
            href="#especialidades"
            class="hero-cta"
          >
            <span>Loren Ipsum</span>
            <Image src={arrow} alt="" width={24} height={24} loading="eager" class="hero-cta-icon" />
          </a>
        </div>

        <div class="hero-visual">
          <Image
            src={fabiano}
            alt="Fabiano Moura"
            loading="eager"
            class="fabiano-photo"
          />

          <Image
            src={elemento}
            alt=""
            loading="eager"
            class="hero-element"
          />
        </div>
      </div>

      <div class="scroll-cue">
        <span>Science in Sports Performance</span>
        <Image src={scroll} alt="" width={22} height={27} loading="eager" class="scroll-icon" />
      </div>
    </section>

    <section id="especialidades" class="landing-fold feature-fold">
      <div class="cream-board">
        <div class="section-heading heading-navy">
          <h2>Lorem ipsum dolor sit amet consectetur</h2>
          <p>Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.</p>
        </div>

        <div class="feature-grid">
          {featureCards.map((card) => (
            <article class="feature-card">
              <div class="feature-card-title">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3.2l2.6 5.27 5.82.85-4.21 4.1.99 5.8L12 16.48 6.8 19.22l.99-5.8-4.21-4.1 5.82-.85L12 3.2Z" />
                </svg>
                <h3>{card.title}</h3>
              </div>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="landing-fold split-fold split-fold-cream" id="sobre">
      <div class="split-copy">
        <p class="section-kicker">Lorem ipsum</p>
        <h2>Lorem ipsum dolor sit amet consectetur.</h2>
        <p>
          Lorem ipsum dolor sit amet consectetur. Sed quam et ullamcorper neque sit sit augue condimentum risus. Lectus fermentum neque sed tortor aliquet eget dictumst sed. Nulla ut congue tempor ultrices cursus.
        </p>
        <a href="#contatos" class="section-cta">
          <span>Loren Ipsum dolor sit</span>
          <Image src={arrow} alt="" width={24} height={24} loading="lazy" class="section-cta-icon" />
        </a>
      </div>

      <div class="image4-stage">
        <Image src={image4} alt="Fabiano Moura" loading="lazy" class="image4-photo" />
      </div>
    </section>

    <section id="avaliacoes" class="landing-fold results-fold">
      <div class="section-heading heading-navy">
        <h2>Lorem ipsum dolor sit amet consectetur.</h2>
        <p>Lorem ipsum dolor sit amet consectetur. Sed quam et ullamcorper neque sit sit augue condimentum risus.</p>
      </div>

      <div class="results-row" aria-label="Avaliações e resultados">
        {resultCards.map((card) => (
          <article class="result-card">
            <Image src={card.image} alt={card.label} loading="lazy" class="result-image" />
          </article>
        ))}
      </div>

      <div class="slider-actions" aria-hidden="true">
        <button type="button">←</button>
        <button type="button">→</button>
      </div>
    </section>

    <section class="landing-fold centered-cta-fold">
      <div class="centered-copy">
        <p>Lorem ipsum dolor sit amet consectetur</p>
        <h2>Lorem ipsum dolor sit amet consectetur</h2>
        <p>
          Lorem ipsum dolor sit amet consectetur. Turpis lectus egestas quam dictum est risus. Commodo sed accumsan ut velit nunc sed vitae quam dolor.
        </p>
        <a href="#contatos" class="section-cta">
          <span>Loren Ipsum dolor sit</span>
          <Image src={arrow} alt="" width={24} height={24} loading="lazy" class="section-cta-icon" />
        </a>
      </div>
    </section>

    <section id="cursos" class="landing-fold feature-fold feature-fold-compact">
      <div class="cream-board">
        <div class="section-heading heading-navy">
          <h2>Lorem ipsum dolor sit amet consectetur</h2>
          <p>Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.</p>
        </div>

        <div class="feature-grid">
          {featureCards.map((card) => (
            <article class="feature-card">
              <div class="feature-card-title">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3.2l2.6 5.27 5.82.85-4.21 4.1.99 5.8L12 16.48 6.8 19.22l.99-5.8-4.21-4.1 5.82-.85L12 3.2Z" />
                </svg>
                <h3>{card.title}</h3>
              </div>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="landing-fold accordion-fold">
      <div class="giant-title" aria-hidden="true">
        <span>Lorem</span>
        <strong>Lorem ipsum dolor</strong>
      </div>

      <div class="accordion-list">
        {accordionItems.map((item, index) => (
          <details class="accordion-item" open={index === 0}>
            <summary>
              <span>{item.title}</span>
              <span class="accordion-arrow">▼</span>
            </summary>
            <p>{item.text}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="landing-fold split-fold image5-fold">
      <div class="image5-card">
        <Image src={image5} alt="Fabiano Moura em ensaio fotográfico" loading="lazy" class="image5-photo" />
      </div>

      <div class="split-copy">
        <p class="section-kicker">Lorem ipsum</p>
        <h2>Lorem ipsum dolor sit amet consectetur.</h2>
        <p>
          Lorem ipsum dolor sit amet consectetur. Sed quam et ullamcorper neque sit sit augue condimentum risus. Lectus fermentum neque sed tortor aliquet eget dictumst sed. Nulla ut congue tempor ultrices cursus.
        </p>
        <a href="#contatos" class="section-cta">
          <span>Loren Ipsum dolor sit</span>
          <Image src={arrow} alt="" width={24} height={24} loading="lazy" class="section-cta-icon" />
        </a>
      </div>
    </section>

    <section id="contatos" class="contact-fold">
      <div class="contact-copy">
        <h2>Lorem ipsum dolor sit amet</h2>
        <p>Lorem ipsum dolor sit amet consectetur. Egestas in dui dictumst duis malesuada platea turpis rhoncus.</p>
      </div>

      <div class="contact-actions">
        <a href="https://api.whatsapp.com/send?phone=5587988674049&amp;text=Ol%C3%A1,%20gostaria%20de%20saber%20mais!." target="_blank" rel="noopener" class="contact-card">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.82 19.82 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.82 19.82 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.9.66 2.8a2 2 0 0 1-.45 2.11L8.05 9.9a16 16 0 0 0 6.05 6.05l1.27-1.27a2 2 0 0 1 2.11-.45c.9.31 1.84.53 2.8.66A2 2 0 0 1 22 16.92Z" />
          </svg>
          <span>
            <strong>Lorem ipsum dolor</strong>
            <small>Lorem ipsum dolor sit amet consectetur.</small>
          </span>
        </a>

        <a href="mailto:contato@fabianomoura.com" class="contact-card">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4 20-7Z" />
            <path d="M22 2 11 13" />
          </svg>
          <span>
            <strong>Lorem ipsum dolor</strong>
            <small>Lorem ipsum dolor sit amet consectetur.</small>
          </span>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    --page-max: 1380px;
    --page-gutter: clamp(20px, 4.4vw, 78px);

    display: flex;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100vh;
    overflow-x: hidden;
    background: #00183e;
    color: #e4d694;
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .hero-shell {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-shell::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background: linear-gradient(90deg, rgba(0, 24, 62, 0.14), rgba(0, 24, 62, 0) 46%, rgba(0, 24, 62, 0.1));
    pointer-events: none;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .site-header {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 40;
    display: grid;
    grid-template-columns: minmax(220px, 350px) minmax(460px, 1fr) minmax(172px, 210px);
    align-items: center;
    gap: clamp(20px, 2.3vw, 32px);
    width: min(calc(100% - (var(--page-gutter) * 2)), var(--page-max));
    margin: 0 auto;
    padding: clamp(22px, 2.6vw, 34px) 0 0;
  }

  .brand-link,
  .brand-logo {
    display: block;
    width: 100%;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(22px, 2vw, 34px);
    color: #e4d694;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
  }

  .site-nav a {
    color: inherit;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .site-nav a:hover {
    color: #fff8c7;
  }

  .private-access,
  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #00183e;
    font-weight: 800;
    text-decoration: none;
    background: linear-gradient(90deg, #d0b362 0%, #fffbd0 100%);
    border-radius: 8px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
    transition: background 160ms ease;
  }

  .private-access:hover,
  .hero-cta:hover {
    background: linear-gradient(90deg, #dbc777 0%, #fffce0 100%);
  }

  .private-access {
    justify-self: end;
    min-width: 188px;
    min-height: 40px;
    gap: 10px;
    padding: 0 18px;
    font-size: 0.9rem;
  }

  .private-icon {
    width: 21px;
    height: 21px;
    flex: 0 0 auto;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: minmax(430px, 0.82fr) minmax(500px, 1fr);
    align-items: center;
    gap: clamp(34px, 4vw, 62px);
    width: min(calc(100% - (var(--page-gutter) * 2)), var(--page-max));
    margin: 0 auto;
    padding: clamp(98px, 9vw, 128px) 0 clamp(64px, 7vw, 92px);
  }

  .hero-copy {
    width: 100%;
    max-width: 600px;
    transform: translateY(10px);
  }

  .hero-kicker {
    margin: 0 0 16px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.1;
  }

  .hero-title {
    max-width: 560px;
    margin: 0;
    font-size: clamp(2.85rem, 4.35vw, 4.25rem);
    font-weight: 800;
    line-height: 0.94;
  }

  .hero-title span {
    display: block;
  }

  .hero-text {
    max-width: 590px;
    margin: 26px 0 0;
    color: #eee5a6;
    font-size: clamp(0.92rem, 1vw, 1rem);
    font-weight: 400;
    line-height: 1.33;
  }

  .hero-cta {
    min-width: 198px;
    min-height: 42px;
    gap: 22px;
    margin-top: 36px;
    padding: 0 24px;
    font-size: 0.9rem;
  }

  .hero-cta-icon {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .hero-visual {
    position: relative;
    align-self: stretch;
    min-height: 0;
    pointer-events: none;
  }

  .fabiano-photo {
    position: absolute;
    right: 1vw;
    bottom: 0;
    z-index: 20;
    width: auto;
    height: clamp(400px, 62svh, 610px);
    max-width: none;
    object-fit: contain;
    filter: drop-shadow(0 24px 34px rgba(0, 0, 0, 0.26));
  }

  .hero-element {
    position: absolute;
    right: -1.5vw;
    bottom: 9svh;
    z-index: 30;
    width: clamp(9rem, 11vw, 14rem);
    height: auto;
    opacity: 0.5;
    filter: blur(1.5px);
    transform: rotate(10deg);
  }

  .scroll-cue {
    position: absolute;
    right: 0;
    bottom: 24px;
    left: 0;
    z-index: 35;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    color: #e4d694;
    font-size: 0.9rem;
    line-height: 1;
    pointer-events: none;
  }

  .scroll-icon {
    width: 18px;
    height: 23px;
  }

  .landing-fold {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    min-height: 100svh;
    overflow: hidden;
    background: #00183e;
  }

  .section-heading {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .section-heading h2,
  .centered-copy h2,
  .split-copy h2,
  .contact-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 2.7vw, 2.8rem);
    font-weight: 800;
    line-height: 1.05;
  }

  .section-heading p {
    max-width: 650px;
    margin: 20px auto 0;
    font-size: clamp(1rem, 1.18vw, 1.16rem);
    line-height: 1.42;
  }

  .heading-navy {
    color: #00183e;
  }

  .feature-fold {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(60px, 6vw, 92px) var(--page-gutter);
  }

  .cream-board {
    width: 100%;
    max-width: var(--page-max);
    padding: clamp(44px, 4vw, 62px) clamp(28px, 6vw, 96px) clamp(52px, 5vw, 76px);
    background: #eee5a6;
    border: 3px solid rgba(0, 24, 62, 0.16);
    border-radius: 8px;
    color: #00183e;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px 36px;
    max-width: 960px;
    margin: 44px auto 0;
  }

  .feature-card {
    min-height: 150px;
    padding: 22px 24px;
    border: 2px solid rgba(0, 24, 62, 0.35);
    border-radius: 8px;
  }

  .feature-card-title {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.85);
  }

  .feature-card svg {
    width: 26px;
    height: 26px;
    flex: 0 0 auto;
  }

  .feature-card svg path {
    fill: none;
    stroke: #00183e;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .feature-card h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .feature-card p {
    margin: 14px 0 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .split-fold {
    display: grid;
    grid-template-columns: minmax(380px, 500px) minmax(480px, 650px);
    align-items: center;
    justify-content: center;
    gap: clamp(38px, 4vw, 68px);
    padding: clamp(64px, 6vw, 96px) var(--page-gutter);
    color: #ffffff;
    background: #020407;
  }

  .split-fold-cream {
    grid-template-columns: minmax(380px, 500px) minmax(560px, 760px);
    overflow: hidden;
    background: #00183e;
  }

  .split-copy {
    position: relative;
    z-index: 10;
    max-width: 620px;
  }

  .section-kicker {
    margin: 0 0 24px;
    font-size: 1.28rem;
    font-weight: 800;
    line-height: 1;
  }

  .split-copy h2 {
    color: #ffffff;
  }

  .split-copy p:not(.section-kicker) {
    margin: 26px 0 0;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.08rem;
    line-height: 1.48;
  }

  .section-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 260px;
    min-height: 46px;
    gap: 16px;
    margin-top: 32px;
    padding: 0 24px;
    color: #00183e;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    background: linear-gradient(90deg, #d0b362 0%, #fffbd0 100%);
    border-radius: 8px;
  }

  .section-cta-icon {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .image4-stage {
    position: relative;
    min-height: min(70svh, 640px);
    margin-right: clamp(-96px, -4vw, -36px);
    overflow: visible;
    background: #00183e;
  }

  .image4-photo {
    position: absolute;
    bottom: clamp(-88px, -6svh, -44px);
    left: clamp(-54px, -2.8vw, -20px);
    width: min(68vw, 1120px);
    max-width: none;
