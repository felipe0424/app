<script>
  // Back-to-top button
  const backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    window.addEventListener('scroll', () => {
      backToTopBtn.classList.toggle('is-visible', window.scrollY > 400);
    }, { passive: true });
    backToTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Hero parallax — mousemove
  const heroShell   = document.querySelector('#inicio') as HTMLElement | null;
  const fabianoPhoto = document.getElementById('fabiano-photo') as HTMLElement | null;
  const heroElem    = document.getElementById('hero-element') as HTMLElement | null;

  if (heroShell && fabianoPhoto && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    heroShell.addEventListener('mousemove', (e: MouseEvent) => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const rect   = heroShell.getBoundingClientRect();
        const cx     = rect.width  / 2;
        const cy     = rect.height / 2;
        const dx     = (e.clientX - rect.left - cx) / cx;
        const dy     = (e.clientY - rect.top  - cy) / cy;
        const moveX  = dx * -10;
        const moveY  = dy *  -7;
        fabianoPhoto.style.transform = `translateX(${moveX}px) translateY(${moveY}px)`;
        if (heroElem) {
          heroElem.style.transform = `rotate(10deg) translateX(${dx * 16}px) translateY(${dy * 10}px)`;
        }
        ticking = false;
      });
    });
    heroShell.addEventListener('mouseleave', () => {
      fabianoPhoto.style.transform = '';
      if (heroElem) heroElem.style.transform = 'rotate(10deg)';
    });
  }

  // Floating header
  const siteHeader = document.querySelector('[data-site-header]');
  const heroSection = document.querySelector('#inicio');

  if (siteHeader && heroSection) {
    const updateFloatingHeader = () => {
      const heroEnd = (heroSection as HTMLElement).offsetTop + (heroSection as HTMLElement).offsetHeight;
      siteHeader.classList.toggle('is-floating', window.scrollY >= heroEnd - 2);
    };
    updateFloatingHeader();
    window.addEventListener('scroll', updateFloatingHeader, { passive: true });
    window.addEventListener('resize', updateFloatingHeader);
  }

  // Scroll reveal
  const revealEls = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
    );
    revealEls.forEach((el) => revealObserver.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  // Results slider will use pure CSS marquee effect.
</script>

