---
import '../styles/global.css';
import logo from '../assets/print.svg';
import background from '../assets/bg-1.png';
---

<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..900&display=swap" rel="stylesheet">
    <title>Projetos</title>
  </head>

  <body class=" flex flex-col items-center justify-center h-screen gap-12">
    <img src={background.src} alt="background" class="absolute top-0 left-0 w-full h-full object-cover -z-1" />
    <img src={logo.src} alt="icon" class="z-1">

    <div class="flex flex-col items-center justify-center bg-white p-8 gap-3 rounded-lg mx-auto max-w-sm">
      <h2 class="text-lg font-bold">Área Restrita</h2>
      <input class="border-2 rounded-lg p-2" type="password" id="password" placeholder="Digite a senha" />
      <button class="bg-purple-800 p-2 rounded-full text-white  px-10" id="login-button">Acessar</button>
    </div>

    <!-- <script>
